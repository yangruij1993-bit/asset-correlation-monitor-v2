# Oracle (optional, A-share/HK ETF from Oracle DB)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_CLIENT_DIR=
ORACLE_SCHEMA=

# Doris (optional, US ETF from Doris)
DORIS_HOST=
DORIS_PORT=9030
DORIS_USER=
DORIS_PASSWORD=
DORIS_DATABASE=

# CORS
CORS_ORIGINS=*

# Strategy signal paths (leave empty to disable)
STRATEGY_DATA_DIR=
WEEKEND_ARB_DIR=
CSI500_TIMING_DIR=
