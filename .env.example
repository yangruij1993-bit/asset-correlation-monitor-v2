# Tushare (required for A-share ETF data)
TUSHARE_TOKEN=

# PostgreSQL (required for data persistence)
DATABASE_URL=postgresql://assetmon:assetmon@localhost:5432/asset_monitor

# CORS
CORS_ORIGINS=*

# Strategy signal directory (optional, default ./strategies/)
# Drop signal_latest.json into strategies/{your-strategy-id}/ to plug in your strategies
# See STRATEGIES.md for the spec
STRATEGY_DIR=./strategies
